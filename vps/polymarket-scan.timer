[Unit]
Description=Polymarket Engine — Market Scanner Timer
Requires=polymarket-scan.service

[Timer]
# Every 5 minutes — VPS has no minute cap unlike GitHub Actions
OnBootSec=30s
OnUnitActiveSec=5min
# If a run is missed (VPS was off), catch up immediately on next boot
Persistent=true

[Install]
WantedBy=timers.target