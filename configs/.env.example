# ============================================================
# POLYMARKET ENGINE — Environment Variables Template
# Copy to .env and fill in real values.
# .env is in .gitignore — NEVER commit it.
# ============================================================

# --- POLYMARKET CLOB API ---
# Get from: https://polymarket.com → connect wallet → API credentials
POLYMARKET_API_KEY=your_api_key_here
POLYMARKET_API_SECRET=your_api_secret_here
POLYMARKET_PASSPHRASE=your_passphrase_here
POLYMARKET_WALLET_ADDRESS=0x_your_wallet_address_here
POLYMARKET_PRIVATE_KEY=your_private_key_no_0x_prefix

# --- POLYGON RPC ---
# Alchemy free tier: 300M compute units/month (more than enough for MVP)
# Get from: https://alchemy.com → create app → Polygon Mainnet
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_FREE_KEY

# --- ANTHROPIC API ---
# Used by: ReviewEngine (daily lessons) + S8 logical arb (LLM classifier)
# Get from: https://console.anthropic.com
# Cost estimate MVP: ~$3-5/month (Haiku model for both uses)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- TELEGRAM BOT (optional but strongly recommended) ---
# Create: message @BotFather on Telegram → /newbot → copy token
# Chat ID: message @userinfobot to get your chat ID
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# --- GITHUB (for MCP server — local only) ---
# MCP server runs on YOUR LOCAL MACHINE, not on GitHub Actions.
# GitHub Actions uses GITHUB_TOKEN automatically (no setup needed there).
# This is only needed if running the MCP server locally for AI agent task management.
GITHUB_TOKEN=ghp_your_personal_access_token
GITHUB_OWNER=your_github_username
GITHUB_REPO=polymarket-engine

# --- ENGINE PATHS ---
DATABASE_PATH=data/trades.db
LESSONS_PATH=data/lessons.json
ENGINE_CONFIG=configs/engine.yaml

# --- SAFETY FLAGS ---
# Set to true for first 3 cycles. Never submit real orders until you've seen 3 dry runs pass.
DRY_RUN=false
MAX_DAILY_LOSS_USDC=5.00
