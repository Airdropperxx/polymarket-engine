# Secrets — NEVER commit
.env
*.pem
*.key

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/
venv/

# SQLite WAL/SHM files — ephemeral, not needed in git
*.db-wal
*.db-shm

# Market cache dir — too large and ephemeral
# data/market_cache/ is replaced by data/market_snapshot.json.gz (committed)
data/market_cache/

# S8 embedding cache is .json (committed) — not this
data/*.jsonl   # audit log can get large

# Logs
logs/
*.log

# HuggingFace model weights — cached by GHA, don't commit
.cache/

# IDE
.idea/
.vscode/
*.swp

# OS
.DS_Store
Thumbs.db

# Test artifacts
.pytest_cache/
.coverage
htmlcov/
